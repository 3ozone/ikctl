# ============================================================
# Docker — MariaDB
# ============================================================
DB_ROOT_PASSWORD=root123
DB_NAME=ikctl_db
DB_USER=ikctl_user
DB_PASSWORD=ikctl_pass123
DB_PORT=3306
DB_HOST=mariadb

# ============================================================
# Docker — PhpMyAdmin
# ============================================================
PHPMYADMIN_PORT=8080

# ============================================================
# Docker — Valkey
# ============================================================
VALKEY_PASSWORD=valkey_pass123
VALKEY_PORT=6379

# ============================================================
# FastAPI
# ============================================================
FASTAPI_PORT=8000
FASTAPI_ENV=development

# ============================================================
# Docker — MailHog (captura de emails en desarrollo)
# ============================================================
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025

# ============================================================
# Settings (leído por pydantic-settings)
# ============================================================

# SQLAlchemy async URL
DB_URL=mysql+aiomysql://ikctl_user:ikctl_pass123@localhost:3306/ikctl_db

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# SMTP (apunta a MailHog en desarrollo)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@ikctl.local
SMTP_FROM_NAME=ikctl

# App
APP_BASE_URL=http://localhost:8000

# Valkey (con password)
VALKEY_URL=redis://:valkey_pass123@localhost:6379/0

# GitHub OAuth (opcional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Apunta al frontend — el navegador recibe el redirect de GitHub y Next.js procesa code+state
GITHUB_REDIRECT_URI=http://localhost:3000/login/github/callback

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Cifrado AES-256-GCM para credenciales en reposo (exactamente 32 bytes ASCII)
ENCRYPTION_KEY=dev-only-key-change-in-prod-0000
